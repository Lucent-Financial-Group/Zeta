{
  "name": "zeta-repo-tooling",
  "private": true,
  "packageManager": "bun@1.3.13",
  "engines": {
    "bun": ">=1.3.13"
  },
  "scripts": {
    "tally:substrates": "bun ./tools/invariant-substrates/tally.ts",
    "lint:typescript": "eslint .",
    "lint:markdown": "markdownlint-cli2",
    "format:check": "prettier --check \"**/*.{json,jsonc,md,markdown,ts,toml,yml,yaml}\"",
    "format:write": "prettier --write \"**/*.{json,jsonc,md,markdown,ts,toml,yml,yaml}\"",
    "typecheck": "tsc --noEmit",
    "test:typescript": "bun test",
    "hygiene:sort-tick-history": "bun ./tools/hygiene/sort-tick-history-canonical.ts",
    "hygiene:fix-markdown": "bun ./tools/hygiene/fix-markdown-md032-md026.ts",
    "shadow": "bun tools/shadow/zeta-shadow.ts"
  },
  "bin": {
    "zeta-shadow": "tools/shadow/zeta-shadow.ts"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/bun": "1.3.12",
    "eslint": "10.2.1",
    "eslint-plugin-sonarjs": "4.0.3",
    "globals": "17.5.0",
    "jiti": "2.6.1",
    "markdownlint-cli2": "0.22.1",
    "prettier": "3.8.3",
    "prettier-plugin-toml": "2.0.6",
    "typescript": "6.0.3",
    "typescript-eslint": "8.59.0"
  },
  "overrides": {
    "smol-toml": "1.6.1"
  }
}
