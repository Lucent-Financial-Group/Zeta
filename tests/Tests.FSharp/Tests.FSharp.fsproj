<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <IsPackable>false</IsPackable>
    <IsTestProject>true</IsTestProject>
    <TreatWarningsAsErrors>true</TreatWarningsAsErrors>
    <!-- xUnit v3 auto-generates the entry point in obj/…/XunitAutoGeneratedEntryPoint.fs; do not supply our own. -->
    <GenerateProgramFile>false</GenerateProgramFile>
  </PropertyGroup>

  <ItemGroup>
    <!-- _Support/ helpers first (they're consumed by subject files below). -->
    <Compile Include="_Support/ConcurrencyHarness.fs" />

    <!-- Algebra/ -->
    <Compile Include="Algebra/Weight.Tests.fs" />
    <Compile Include="Algebra/ZSet.Tests.fs" />
    <Compile Include="Algebra/ZSet.Overflow.Tests.fs" />
    <Compile Include="Algebra/IndexedZSet.Tests.fs" />

    <!-- Circuit/ -->
    <Compile Include="Circuit/Circuit.Tests.fs" />
    <Compile Include="Circuit/Incremental.Tests.fs" />
    <Compile Include="Circuit/NestedCircuit.Tests.fs" />
    <Compile Include="Circuit/Plan.Tests.fs" />
    <Compile Include="Circuit/Plan.Branches.Tests.fs" />

    <!-- Operators/ -->
    <Compile Include="Operators/Aggregate.Tests.fs" />
    <Compile Include="Operators/Window.Tests.fs" />
    <Compile Include="Operators/Window.FiringMode.Tests.fs" />
    <Compile Include="Operators/Join.Tests.fs" />
    <Compile Include="Operators/Upsert.Tests.fs" />
    <Compile Include="Operators/Transaction.Tests.fs" />
    <Compile Include="Operators/Fusion.Tests.fs" />
    <Compile Include="Operators/ResidualMax.Tests.fs" />
    <Compile Include="Operators/Differentiate.Tests.fs" />
    <Compile Include="Operators/RecursiveCounting.MultiSeed.Tests.fs" />

    <!-- Storage/ -->
    <Compile Include="Storage/Spine.Tests.fs" />
    <Compile Include="Storage/Spine.Selector.Tests.fs" />
    <Compile Include="Storage/Spine.Balanced.Tests.fs" />
    <Compile Include="Storage/Spine.Disk.Tests.fs" />
    <Compile Include="Storage/Checkpoint.Tests.fs" />
    <Compile Include="Storage/Merkle.Tests.fs" />
    <Compile Include="Storage/FastCdc.Tests.fs" />
    <Compile Include="Storage/ClosureTable.Tests.fs" />
    <Compile Include="Storage/Simd.Tests.fs" />
    <Compile Include="Storage/Durability.Tests.fs" />

    <!-- Sketches/ -->
    <Compile Include="Sketches/Bloom.Tests.fs" />
    <Compile Include="Sketches/HyperLogLog.Tests.fs" />
    <Compile Include="Sketches/HyperMinHash.Tests.fs" />
    <Compile Include="Sketches/CountMin.Tests.fs" />
    <Compile Include="Sketches/Kll.Tests.fs" />
    <Compile Include="Sketches/Haar.Tests.fs" />
    <Compile Include="Sketches/Tropical.Tests.fs" />

    <!-- Runtime/ -->
    <Compile Include="Runtime/Runtime.Tests.fs" />
    <Compile Include="Runtime/Mailbox.Tests.fs" />
    <Compile Include="Runtime/Shard.Tests.fs" />
    <Compile Include="Runtime/ConsistentHash.Tests.fs" />
    <Compile Include="Runtime/Concurrency.Tests.fs" />
    <Compile Include="Runtime/Allocation.Tests.fs" />

    <!-- Infra/ -->
    <Compile Include="Infra/Metrics.Tests.fs" />
    <Compile Include="Infra/Tracing.Tests.fs" />
    <Compile Include="Infra/Watermark.Tests.fs" />
    <Compile Include="Infra/Sink.Tests.fs" />
    <Compile Include="Infra/Dsl.Tests.fs" />
    <Compile Include="Infra/Environment.Tests.fs" />
    <Compile Include="Infra/Rx.Tests.fs" />

    <!-- Crdt/ -->
    <Compile Include="Crdt/GCounter.Tests.fs" />
    <Compile Include="Crdt/PNCounter.Tests.fs" />
    <Compile Include="Crdt/OrSet.Tests.fs" />
    <Compile Include="Crdt/Lww.Tests.fs" />

    <!-- Plugin/ -->
    <Compile Include="Plugin/Harness.Tests.fs" />

    <!-- Formal/ -->
    <Compile Include="Formal/Z3.Laws.Tests.fs" />
    <Compile Include="Formal/Tlc.Runner.Tests.fs" />
    <Compile Include="Formal/Alloy.Runner.Tests.fs" />
    <Compile Include="Formal/Sharder.InfoTheoretic.Tests.fs" />

    <!-- Properties/ last (they cross modules by design). -->
    <Compile Include="Properties/Math.Invariants.Tests.fs" />
    <Compile Include="Properties/Fuzz.Tests.fs" />
    <Compile Include="Properties/Determinism.Tests.fs" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\src\Core\Core.fsproj" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="FSharp.Core" />
    <PackageReference Include="System.IO.Hashing" />
    <PackageReference Include="System.Reactive" />
    <PackageReference Include="System.Numerics.Tensors" />
    <PackageReference Include="Microsoft.NET.Test.Sdk" />
    <PackageReference Include="xunit.v3" />
    <PackageReference Include="xunit.runner.visualstudio">
      <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
      <PrivateAssets>all</PrivateAssets>
    </PackageReference>
    <PackageReference Include="FsCheck" />
    <PackageReference Include="FsCheck.Xunit.v3" />
    <PackageReference Include="FsUnit.Xunit" />
    <PackageReference Include="Unquote" />
    <PackageReference Include="coverlet.collector">
      <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
      <PrivateAssets>all</PrivateAssets>
    </PackageReference>
    <PackageReference Include="coverlet.msbuild">
      <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
      <PrivateAssets>all</PrivateAssets>
    </PackageReference>
  </ItemGroup>
</Project>
